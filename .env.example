# Supabase project credentials.
# Find these in your Supabase project: Project Settings > API.
# Never put the service-role key here — only the anon/public key is safe
# to ship inside the mobile app.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Selects which data source the app's services read/write through.
#   mock     - use src/data/mock, no network calls (default, safe with no setup)
#   supabase - use the real Supabase backend (requires the two values above)
EXPO_PUBLIC_DATA_SOURCE=mock
